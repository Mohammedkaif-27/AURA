# ═══════════════════════════════════════════════════════════
# AURA — Environment Variables
# Copy this file to .env and fill in your actual values.
# ═══════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────
# "groq" (default) or "nvidia"
LLM_PROVIDER=groq

# Groq (primary — free tier available)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM (fallback — free tier available)
# Only needed if LLM_PROVIDER=nvidia
# NVIDIA_API_KEY=your-nvidia-api-key-here
# NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ── Embeddings (local, free) ─────────────────────────────
# Default: BAAI/bge-small-en-v1.5 (~130MB, good accuracy)
# Alternative: all-MiniLM-L6-v2 (~80MB, lower resource usage)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Reranker (local, free) ───────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Supabase (create a new free project at supabase.com) ─
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── SMTP Email (for notifications) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password-here
SENDER_EMAIL=your-email@gmail.com

# ── Admin Authorization ──────────────────────────────────
# Comma-separated list of admin email addresses.
# Also supports Supabase user_metadata.is_admin=true flag.
ADMIN_EMAILS=admin@example.com

# ── Optional ─────────────────────────────────────────────
# Redis (for session cache — falls back to in-memory if unset)
# REDIS_URL=redis://localhost:6379/0

# ChromaDB persistence path (default: backend/chroma_db)
# CHROMA_DB_PATH=backend/chroma_db

# Server port (default: 8080)
# PORT=8080
